@font-face {
  font-family: 'Oswald-Variable';
  src: url('<%= asset_path "Oswald-VariableFont_wght.ttf" %>') format('truetype');
  font-display: swap;
}

@font-face {
  font-family: 'Oswald-Regular';
  src: url('<%= asset_path "Oswald-Regular.ttf" %>') format('truetype');
  font-display: swap;
}

/* ---- CV template fonts (self-hosted, free) ---- */

