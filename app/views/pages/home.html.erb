<section class="min-h-screen lg:min-h-[90vh] bg-light flex items-center overflow-hidden">
  <div class="w-full max-w-7xl mx-auto px-6 lg:px-16 py-24 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <span class="block text-xs font-bold uppercase tracking-[0.35em] text-porange mb-8">
        Professional Resume Builder
      </span>
      <h1 class="text-6xl xl:text-7xl font-serif font-black text-pdark leading-[1.05] tracking-tight">
        Build a CV<br>
        that <span class="text-porange">opens</span><br>
        <span class="text-porange">doors.</span>
      </h1>
      <p class="mt-8 text-lg text-ldark max-w-md leading-relaxed">
        A guided, distraction-free flow to create a polished resume —
        in minutes, not hours. Professional results without the complexity.
      </p>
      <div class="mt-12 flex flex-wrap items-center gap-4">
        <%= link_to new_form_path, class: "group inline-flex items-center gap-3 px-8 py-4 bg-porange text-light text-sm font-bold uppercase tracking-widest hover:bg-pdark transition-colors duration-300" do %>
          Get Started
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        <% end %>
        <%= link_to "Browse Examples", examples_path, class: "inline-flex items-center px-8 py-4 border-2 border-ldark text-ldark text-sm font-bold uppercase tracking-widest hover:border-porange hover:text-porange transition-colors duration-300" %>
      </div>

      <%# Quick facts — honest, no fabricated stats %>
      <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4 text-sm text-ldark">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-porange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
          </svg>
          Free — no signup required
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-porange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
          </svg>
          One guided form
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-porange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
          </svg>
          Print or save as PDF
        </span>
      </div>
    </div>

    <div class="hidden lg:block relative h-[640px] 2xl:h-[680px]">
      <span class="absolute font-serif font-black text-beige/40 leading-none select-none pointer-events-none" style="font-size: 22rem; top: 50%; left: 50%; transform: translate(-42%, -52%);">1</span>
      <%= image_tag "CV2.png", class: "absolute w-64 xl:w-72 2xl:w-80 rounded shadow-xl border border-beige/60 opacity-60 -rotate-6 z-0 top-[10%] left-[8%]" %>
      <%= image_tag "CV3.png", class: "absolute w-64 xl:w-72 2xl:w-80 rounded shadow-xl border border-beige/60 opacity-60 rotate-12 z-0 top-[8%] left-[22%]" %>
      <%= image_tag "CV1.png", class: "absolute w-64 xl:w-72 2xl:w-80 rounded shadow-2xl border-2 border-beige z-10 top-[8%] left-[15%]" %>

      <%# Floating badge anchoring the lower-right of the stack %>
      <div class="hidden lg:flex absolute bottom-[6%] right-[4%] z-20 items-center gap-2 bg-light border border-beige shadow-lg rounded px-4 py-3">
        <svg class="w-4 h-4 text-porange flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest text-pdark">Profile · Experience · Education · Skills</span>
      </div>
    </div>
  </div>
</section>

<section class="bg-pdark py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">
    <p class="text-porange text-xs font-bold uppercase tracking-[0.35em]">The process</p>
    <h2 class="mt-4 text-4xl xl:text-5xl font-serif font-black text-light leading-tight max-w-xl">
      From blank page to interview-ready.
    </h2>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-10">

      <div class="border-t-2 border-porange pt-8">
        <p class="text-3xl font-serif font-black text-porange mb-6">01</p>
        <h3 class="text-xl font-bold text-light mb-3">Fill in your details</h3>
        <p class="text-beige leading-relaxed">
          Walk through a guided form — profile, work history, education, skills,
          languages, and references. One clear step at a time.
        </p>
      </div>

      <div class="border-t-2 border-porange pt-8">
        <p class="text-3xl font-serif font-black text-porange mb-6">02</p>
        <h3 class="text-xl font-bold text-light mb-3">Preview your CV</h3>
        <p class="text-beige leading-relaxed">
          Your resume takes shape in real time. Review it, tweak it, refine it —
          until it says exactly what you want it to say.
        </p>
      </div>

      <div class="border-t-2 border-porange pt-8">
        <p class="text-3xl font-serif font-black text-porange mb-6">03</p>
        <h3 class="text-xl font-bold text-light mb-3">Apply with confidence</h3>
        <p class="text-beige leading-relaxed">
          Download or share your polished CV and go after the roles you actually want.
          Your next opportunity starts here.
        </p>
      </div>

    </div>
  </div>
</section>

<section class="bg-light py-24">
  <div class="max-w-7xl mx-auto px-6 lg:px-16">
    <div class="border-t-2 border-beige pt-12 flex flex-col md:flex-row md:items-end justify-between gap-10">

      <div>
        <p class="text-porange text-xs font-bold uppercase tracking-[0.35em]">Inspiration</p>
        <h2 class="mt-4 text-4xl xl:text-5xl font-serif font-black text-pdark leading-tight">
          See what's possible.
        </h2>
        <p class="mt-4 text-ldark max-w-md leading-relaxed">
          Browse CVs built on Station1 and see the quality of resumes our users
          create every day.
        </p>
      </div>

      <%= link_to examples_path, class: "group flex-shrink-0 inline-flex items-center gap-3 px-8 py-4 bg-ldark text-light text-sm font-bold uppercase tracking-widest hover:bg-porange transition-colors duration-300" do %>
        Browse Gallery
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      <% end %>

    </div>
  </div>
</section>

<section class="bg-porange py-20">
  <div class="max-w-7xl mx-auto px-6 lg:px-16 flex flex-col md:flex-row items-center justify-between gap-8">

    <div>
      <h2 class="text-3xl xl:text-4xl font-serif font-black text-light leading-tight">
        Your next job starts with a great CV.
      </h2>
      <p class="mt-3 text-light/80 max-w-md">
        Station1 makes it simple. Start for free, build in minutes.
      </p>
    </div>

    <%= link_to new_form_path, class: "group flex-shrink-0 inline-flex items-center gap-3 px-10 py-5 bg-light text-pdark text-sm font-bold uppercase tracking-widest hover:bg-pdark hover:text-light transition-colors duration-300" do %>
      Start Building Now
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    <% end %>

  </div>
</section>
