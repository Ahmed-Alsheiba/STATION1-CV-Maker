<div data-nested-form-row class="border-2 border-beige p-4 space-y-3">
  <div class="flex flex-wrap gap-3">
    <%= f.text_field :job_title, class: input_class + " sm:w-[calc(50%-0.375rem)]", placeholder: "Job Title" %>
    <%= f.text_field :company, class: input_class + " sm:w-[calc(50%-0.375rem)]", placeholder: "Company" %>
  </div>
  <div class="flex flex-wrap gap-3">
    <%= f.text_field :location, class: input_class + " sm:w-[calc(50%-0.375rem)]", placeholder: "Location / City" %>
    <%= f.text_field :start_date, class: input_class + " sm:w-[calc(25%-0.5625rem)]", placeholder: "Start (Jan 2021)" %>
    <%= f.text_field :end_date, class: input_class + " sm:w-[calc(25%-0.5625rem)]", placeholder: "End (or Present)" %>
  </div>
  <%= f.text_area :description, class: textarea_class + " h-24", placeholder: "Description — one bullet per line" %>
  <div class="flex justify-end">
    <%= f.hidden_field :_destroy %>
    <button type="button" data-action="nested-form#remove" class="text-xs font-bold uppercase tracking-widest text-porange hover:text-pdark transition-colors duration-200">Remove</button>
  </div>
</div>
