<div data-nested-form-row class="border-2 border-beige p-4 space-y-3">
  <div class="flex flex-wrap gap-3">
    <%= f.text_field :degree, class: input_class + " sm:w-[calc(50%-0.375rem)]", placeholder: "Degree" %>
    <%= f.text_field :institution, class: input_class + " sm:w-[calc(50%-0.375rem)]", placeholder: "Institution / College" %>
  </div>
  <div class="flex flex-wrap gap-3">
    <%= f.text_field :start_date, class: input_class + " sm:w-[calc(50%-0.375rem)]", placeholder: "Start (e.g. 2015)" %>
    <%= f.text_field :end_date, class: input_class + " sm:w-[calc(50%-0.375rem)]", placeholder: "End (e.g. 2019)" %>
  </div>
  <div class="flex justify-end">
    <%= f.hidden_field :_destroy %>
    <button type="button" data-action="nested-form#remove" class="text-xs font-bold uppercase tracking-widest text-porange hover:text-pdark transition-colors duration-200">Remove</button>
  </div>
</div>
