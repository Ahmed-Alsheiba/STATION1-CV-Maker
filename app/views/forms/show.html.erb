<%# ================================================================ %>
<%# show.html.erb — STATION1 CV Output                              %>
<%# Page chrome only. The actual CV card markup lives in            %>
<%# app/views/forms/templates/_default.html.erb and _special.html.erb, %>
<%# selected at render time based on @form.template.                %>
<%# ================================================================ %>

<div class="bg-light py-12 flex justify-center print:p-0 print:bg-white mt-5">
  <%= render "forms/templates/#{@form.template}", form: @form %>
</div>

<div class="no-print bg-pdark py-6 flex justify-center">
  <button onclick="window.print()"
          class="group inline-flex items-center gap-3 px-8 py-4 bg-porange text-light text-sm font-bold uppercase tracking-widest hover:bg-light hover:text-pdark transition-colors duration-300">
    Print / Save as PDF
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a1 1 0 001-1v-5H8v5a1 1 0 001 1zm0-12V4a1 1 0 011-1h4a1 1 0 011 1v5H9z"/>
    </svg>
  </button>
</div>
