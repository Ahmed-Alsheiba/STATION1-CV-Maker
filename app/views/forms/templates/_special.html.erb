<%# ================================================================ %>
<%# _special.html.erb — STATION1 CV Output, Special template        %>
<%# Sidebar Professional: full-height dark sidebar + light content. %>
<%# id="template" is targeted by the print CSS in                   %>
<%# app/assets/stylesheets/application.scss — keep this id stable.  %>
<%# ================================================================ %>

<div class="grid grid-cols-3 content-stretch bg-white border border-beige shadow-2xl w-full max-w-[900px] print:border-0 print:shadow-none print:max-w-none tpl-special" id="template">

  <div class="col-span-1 bg-pdark p-10" id="sidebar">
    <div class="max-w-[160px] mx-auto" id="photo">
      <% if form.photo.attached? %>
        <%= image_tag form.photo, class: "aspect-square w-full object-cover rounded-full border-2 border-porange" %>
      <% else %>
        <%= image_tag "personalPhoto.png", class: "aspect-square w-full object-cover rounded-full border-2 border-porange" %>
      <% end %>
    </div>

    <div class="mt-8" id="contact">
      <p class="text-porange text-xs font-bold uppercase tracking-widest">Contact</p>
      <p class="mt-2 text-light text-xs leading-relaxed"><%= form.email %></p>
      <p class="mt-1 text-light text-xs leading-relaxed"><%= form.phone %></p>
      <p class="mt-1 text-light text-xs leading-relaxed"><%= form.address %></p>
    </div>

    <div class="mt-8" id="education">
      <p class="text-porange text-xs font-bold uppercase tracking-widest">Education</p>
      <% form.educations.each do |edu| %>
        <div class="mt-2">
          <p class="text-sm font-bold text-light"><%= edu.degree %></p>
          <p class="text-xs text-beige"><%= edu.institution %></p>
          <p class="text-xs text-beige"><%= cv_date_range(edu.start_date, edu.end_date) %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-8" id="skills">
      <p class="text-porange text-xs font-bold uppercase tracking-widest">Skills</p>
      <ul class="mt-2 space-y-1">
        <% form.skills.each do |skill| %>
          <li class="text-xs text-light"><%= skill.name %></li>
        <% end %>
      </ul>
    </div>

    <div class="mt-8" id="languages">
      <p class="text-porange text-xs font-bold uppercase tracking-widest">Languages</p>
      <ul class="mt-2 space-y-1">
        <% form.languages.each do |language| %>
          <li class="text-xs text-light"><%= language.name %></li>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="col-span-2 p-10" id="main">
    <h1 class="text-6xl font-serif font-black text-pdark leading-tight"><%= form.first_name %></h1>
    <h1 class="text-6xl font-serif font-black text-ldark leading-tight"><%= form.last_name %></h1>

    <div class="mt-6" id="about">
      <p class="text-porange text-xs font-bold uppercase tracking-widest">Profile</p>
      <p class="mt-2 text-sm text-pdark leading-snug"><%= form.about_you %></p>
    </div>

    <div class="mt-6" id="experience">
      <p class="text-porange text-xs font-bold uppercase tracking-widest">Experience</p>
      <% form.experiences.each do |exp| %>
        <div class="mt-3">
          <p class="text-base font-bold text-pdark"><%= exp.job_title %></p>
          <p class="text-sm font-semibold text-ldark"><%= exp.company %></p>
          <p class="text-xs text-beige"><%= exp.location %></p>
          <p class="text-xs text-beige"><%= cv_date_range(exp.start_date, exp.end_date) %></p>
          <p class="mt-2 text-sm text-pdark leading-snug"><%= exp.description %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-6" id="reference">
      <p class="text-porange text-xs font-bold uppercase tracking-widest">Reference</p>
      <% form.cv_references.each do |ref| %>
        <p class="mt-2 text-xs text-pdark"><%= ref.name %></p>
        <p class="text-xs text-ldark"><%= ref.email %> · <%= ref.phone %></p>
      <% end %>
    </div>
  </div>

</div>
