<%# ================================================================ %>
<%# _minimal.html.erb — White Clean Minimalist (Real Estate)        %>
<%# Black-on-white, thin divider, no photo. tpl-minimal pads itself. %>
<%# ================================================================ %>

<div class="bg-white border border-beige shadow-2xl w-full max-w-[900px] font-opensans text-black p-12 print:border-0 print:shadow-none print:max-w-none tpl-minimal" id="template">

  <%# ── HEADER ─────────────────────────────────────────────────── %>
  <header class="text-center pb-6 border-b border-black" id="header">
    <h1 class="text-4xl font-light uppercase tracking-[0.35em] leading-tight"><%= form.first_name %> <%= form.last_name %></h1>
    <% if form.experiences.first&.job_title.present? %>
      <p class="mt-3 text-sm italic tracking-wide text-minimal-muted"><%= form.experiences.first.job_title %></p>
    <% end %>
  </header>

  <div class="grid grid-cols-[5fr_8fr] gap-8 pt-8">

    <%# ── LEFT COLUMN ──────────────────────────────────────────── %>
    <div class="space-y-7 border-r border-black pr-8" id="left">
      <section id="contact">
        <h2 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">Contact</h2>
        <div class="space-y-1.5 text-xs leading-relaxed">
          <p><%= form.phone %></p>
          <p class="break-words"><%= form.email %></p>
          <p><%= form.address %></p>
        </div>
      </section>

      <section id="education">
        <h2 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">Education</h2>
        <% form.educations.each do |edu| %>
          <div class="mb-3">
            <p class="text-xs font-bold uppercase"><%= edu.institution %></p>
            <p class="text-xs text-minimal-muted"><%= cv_date_range(edu.start_date, edu.end_date) %></p>
            <p class="text-xs"><%= edu.degree %></p>
          </div>
        <% end %>
      </section>

      <% if form.certifications.any? %>
        <section id="certifications">
          <h2 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">Awards &amp; Certifications</h2>
          <ul class="space-y-1.5 text-xs list-disc list-outside pl-4">
            <% form.certifications.each do |cert| %>
              <li><%= cert.name %></li>
            <% end %>
          </ul>
        </section>
      <% end %>

      <section id="skills">
        <h2 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">Skills</h2>
        <ul class="space-y-1.5 text-xs list-disc list-outside pl-4">
          <% form.skills.each do |skill| %>
            <li><%= skill.name %></li>
          <% end %>
        </ul>
      </section>
    </div>

    <%# ── RIGHT COLUMN ─────────────────────────────────────────── %>
    <div class="space-y-7" id="right">
      <section id="profile">
        <h2 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">Profile</h2>
        <p class="text-xs leading-relaxed font-light"><%= form.about_you %></p>
      </section>

      <section id="experience">
        <h2 class="text-sm font-bold uppercase tracking-[0.2em] mb-4">Work Experience</h2>
        <div class="space-y-5">
          <% form.experiences.each do |exp| %>
            <div>
              <p class="text-xs font-bold uppercase tracking-wide"><%= exp.job_title %></p>
              <div class="flex justify-between items-baseline gap-3">
                <p class="text-xs font-semibold"><%= [exp.company, exp.location].reject(&:blank?).join(", ") %></p>
                <p class="text-xs italic text-minimal-muted whitespace-nowrap"><%= cv_date_range(exp.start_date, exp.end_date) %></p>
              </div>
              <% bullets = cv_bullets(exp.description) %>
              <% if bullets.any? %>
                <ul class="mt-2 space-y-1 text-xs list-disc list-outside pl-4">
                  <% bullets.each do |b| %>
                    <li><%= b %></li>
                  <% end %>
                </ul>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    </div>

  </div>
</div>
