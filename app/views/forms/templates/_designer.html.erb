<%# ================================================================ %>
<%# _designer.html.erb — White & Beige Minimalist (Graphic Designer) %>
<%# id="template" + tpl-designer are targeted by the print CSS.      %>
<%# ================================================================ %>

<div class="grid grid-cols-[34%_66%] content-stretch bg-white border border-beige shadow-2xl w-full max-w-[900px] font-garet text-[#2b2b2b] print:border-0 print:shadow-none print:max-w-none tpl-designer" id="template">

  <%# ── LEFT SIDEBAR ───────────────────────────────────────────── %>
  <aside class="bg-designer-beige p-8" id="sidebar">
    <div class="w-36 h-36 mx-auto rounded-full overflow-hidden border-4 border-white shadow-sm" id="photo">
      <% if form.photo.attached? %>
        <%= image_tag form.photo, class: "w-full h-full object-cover" %>
      <% else %>
        <%= image_tag "personalPhoto.png", class: "w-full h-full object-cover" %>
      <% end %>
    </div>

    <div class="mt-8" id="contact">
      <h2 class="font-publicsans text-sm font-bold uppercase tracking-[0.2em] text-designer-accent">Contact</h2>
      <div class="mt-3 space-y-2 text-xs leading-relaxed">
        <p><%= form.phone %></p>
        <p class="break-words"><%= form.email %></p>
        <p><%= form.address %></p>
      </div>
    </div>

    <div class="mt-8" id="education">
      <h2 class="font-publicsans text-sm font-bold uppercase tracking-[0.2em] text-designer-accent">Education</h2>
      <% form.educations.each do |edu| %>
        <div class="mt-3">
          <p class="text-sm font-bold"><%= edu.degree %></p>
          <p class="text-xs text-[#6b6b6b]"><%= cv_date_range(edu.start_date, edu.end_date) %></p>
          <p class="text-xs"><%= edu.institution %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-8" id="skills">
      <h2 class="font-publicsans text-sm font-bold uppercase tracking-[0.2em] text-designer-accent">Skills</h2>
      <ul class="mt-3 space-y-2">
        <% form.skills.each do |skill| %>
          <li class="flex items-center justify-between gap-3">
            <span class="text-xs"><%= skill.name %></span>
            <% if skill.level.present? %>
              <span class="flex gap-1 flex-shrink-0"><%= skill_dots(skill.level, filled: "bg-designer-accent", empty: "bg-designer-accent/25") %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </aside>

  <%# ── RIGHT MAIN ─────────────────────────────────────────────── %>
  <main id="main">
    <header class="bg-designer-sidebar px-10 py-8" id="namebar">
      <h1 class="font-publicsans text-4xl font-extrabold uppercase tracking-wide leading-none"><%= form.first_name %> <%= form.last_name %></h1>
      <% if form.experiences.first&.job_title.present? %>
        <p class="mt-2 font-publicsans text-sm uppercase tracking-[0.3em] text-designer-accent"><%= form.experiences.first.job_title %></p>
      <% end %>
      <% if form.about_you.present? %>
        <p class="mt-4 text-xs leading-relaxed text-[#4a4a4a]"><%= form.about_you %></p>
      <% end %>
    </header>

    <div class="px-10 py-8 space-y-8">
      <section id="experience">
        <h2 class="font-publicsans text-base font-bold uppercase tracking-[0.2em]">Experience</h2>
        <div class="mt-4 space-y-5">
          <% form.experiences.each do |exp| %>
            <div class="flex gap-3">
              <span class="mt-1.5 w-2.5 h-2.5 rounded-full bg-designer-accent flex-shrink-0"></span>
              <div class="flex-1">
                <div class="flex justify-between items-baseline gap-3">
                  <p class="text-sm font-bold"><%= exp.job_title %></p>
                  <p class="text-xs text-[#777] whitespace-nowrap"><%= cv_date_range(exp.start_date, exp.end_date) %></p>
                </div>
                <p class="text-xs font-semibold text-designer-accent"><%= [exp.company, exp.location].reject(&:blank?).join(" · ") %></p>
                <p class="mt-1 text-xs leading-relaxed text-[#4a4a4a]"><%= exp.description %></p>
              </div>
            </div>
          <% end %>
        </div>
      </section>

      <% if form.languages.any? %>
        <section id="languages">
          <h2 class="font-publicsans text-base font-bold uppercase tracking-[0.2em]">Language</h2>
          <div class="mt-4 grid grid-cols-3 gap-4">
            <% form.languages.each do |lang| %>
              <div>
                <p class="text-xs mb-1"><%= lang.name %></p>
                <% if lang.level.present? %>
                  <div class="h-1.5 w-full bg-designer-accent/20 rounded-full overflow-hidden">
                    <div class="h-full bg-designer-accent rounded-full" style="width: <%= level_percent(lang.level) %>%"></div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if form.cv_references.any? %>
        <section id="reference">
          <h2 class="font-publicsans text-base font-bold uppercase tracking-[0.2em]">Reference</h2>
          <div class="mt-4 grid grid-cols-2 gap-6">
            <% form.cv_references.each do |ref| %>
              <div>
                <p class="text-sm font-bold"><%= ref.name %></p>
                <p class="text-xs text-designer-accent"><%= [ref.title, ref.company].reject(&:blank?).join(" · ") %></p>
                <p class="mt-1 text-xs"><%= ref.phone %></p>
                <p class="text-xs break-words"><%= ref.email %></p>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  </main>

</div>
