# Copy to /var/www/station1/shared/.env on the server, fill in the values,
# then `chmod 600` it. Loaded by systemd (EnvironmentFile) and bin/deploy.sh.
# Do NOT commit a filled-in copy — it contains secrets.

RAILS_ENV=production
RACK_ENV=production

# Contents of config/master.key (gitignored). Decrypts credentials.yml.enc.
# SECRET_KEY_BASE is NOT needed — it is derived from this.
RAILS_MASTER_KEY=PASTE_CONTENTS_OF_config_master.key

# Postgres role/db created in Part B step 2.
DATABASE_URL=postgres://station1:STRONG_DB_PASSWORD@localhost:5432/station1_production

# Public hostname (no scheme). Used by Action Mailer default_url_options.
APP_HOST=station1.me

# Puma unix socket that Nginx proxies to (must match the Nginx upstream).
PUMA_SOCKET=/var/www/station1/current/tmp/sockets/puma.sock

# Active Storage uploads live outside the code dir so redeploys never touch them.
STORAGE_PATH=/var/www/station1/shared/storage

# Concurrency. workers x threads — keep within DB pool (RAILS_MAX_THREADS).
WEB_CONCURRENCY=2
RAILS_MAX_THREADS=5

# Send logs to stdout so journalctl captures them.
RAILS_LOG_TO_STDOUT=true

# Leave empty: Nginx serves /public directly.
RAILS_SERVE_STATIC_FILES=

# --- SMTP (Devise password-reset email) -------------------------------------
# DEFERRED for now — leaving these empty is fine. Everything works except the
# "forgot password" flow (it will error if triggered, because
# raise_delivery_errors is true). Fill these in later from your provider
# (Resend / Postmark / SendGrid / Mailgun) and restart the service.
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
